class MainScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        delayed_tasks.add_observer(self)
        self.build_ui()

    def build_ui(self):
        layout = BoxLayout(orientation='vertical')
        
        top = BoxLayout(size_hint_y=None, height=dp(60), padding=[dp(15), dp(10)])
        rounded_rect(top, PRIMARY, 0)
        top.add_widget(Label(text='🍔 FOOD FACTORY', color=CARD, bold=True, font_size=sp(18)))
        logout = Button(text='Выход', size_hint_x=0.18, background_color=DANGER, color=CARD, font_size=sp(12))
        logout.bind(on_press=self.logout)
        top.add_widget(logout)
        layout.add_widget(top)
        
        scroll = ScrollView()
        content = GridLayout(cols=1, padding=[dp(15), dp(15), dp(15), dp(15)], spacing=dp(15), size_hint_y=None)
        content.bind(minimum_height=content.setter('height'))
        
        self.user_label = Label(text='', size_hint_y=None, height=dp(40), font_size=sp(16), color=TEXT)
        content.add_widget(self.user_label)
        
        # Карточка статистики
        stat_card = BoxLayout(orientation='vertical', size_hint_y=None, height=dp(130), padding=[dp(15), dp(10)], spacing=dp(5))
        rounded_rect(stat_card, PRIMARY, dp(14))
        stat_card.add_widget(Label(text='СТАТИСТИКА', color=SECONDARY, bold=True, size_hint_y=None, height=dp(25), font_size=sp(12)))
        
        stat_row = BoxLayout(spacing=dp(20), size_hint_y=None, height=dp(50))
        self.total = Label(text='0', font_size=sp(26), bold=True, color=SECONDARY)
        self.active = Label(text='0', font_size=sp(26), bold=True, color=WARNING)
        self.completed = Label(text='0', font_size=sp(26), bold=True, color=SUCCESS)
        stat_row.add_widget(self.total)
        stat_row.add_widget(self.active)
        stat_row.add_widget(self.completed)
        stat_card.add_widget(stat_row)
        
        cap_row = BoxLayout(spacing=dp(20), size_hint_y=None, height=dp(25))
        cap_row.add_widget(Label(text='Всего', color=SECONDARY, font_size=sp(10)))
        cap_row.add_widget(Label(text='Активных', color=WARNING, font_size=sp(10)))
        cap_row.add_widget(Label(text='Готово', color=SUCCESS, font_size=sp(10)))
        stat_card.add_widget(cap_row)
        content.add_widget(stat_card)
        
        # Отложенные задачи
        tasks_card = BoxLayout(orientation='vertical', size_hint_y=None, height=dp(80), padding=[dp(12), dp(8)], spacing=dp(4))
        rounded_rect(tasks_card, CARD, dp(12))
        tasks_card.add_widget(Label(text='⏰ ОТЛОЖЕННЫЕ ЗАДАЧИ', bold=True, size_hint_y=None, height=dp(20), color=TEXT, font_size=sp(10)))
        self.tasks_info = Label(text='Нет задач', size_hint_y=None, height=dp(25), color=TEXT_LIGHT, font_size=sp(11))
        tasks_card.add_widget(self.tasks_info)
        self.tasks_count = Label(text='', size_hint_y=None, height=dp(20), color=INFO, font_size=sp(10))
        tasks_card.add_widget(self.tasks_count)
        content.add_widget(tasks_card)
        
        content.add_widget(Label(text='Быстрые действия', bold=True, size_hint_y=None, height=dp(35), font_size=sp(14), color=TEXT))
        
        btn1 = Button(text='📝 СОЗДАТЬ ЗАЯВКУ', size_hint_y=None, height=dp(55), font_size=sp(14), background_color=SUCCESS, color=CARD)
        btn1.bind(on_press=lambda x: setattr(self.manager, 'current', 'new_claim'))
        content.add_widget(btn1)
        
        btn2 = Button(text='📋 МОИ ЗАЯВКИ', size_hint_y=None, height=dp(55), font_size=sp(14), background_color=INFO, color=CARD)
        btn2.bind(on_press=lambda x: setattr(self.manager, 'current', 'my_claims'))
        content.add_widget(btn2)
        
        btn3 = Button(text='📄 ОТЧЁТЫ', size_hint_y=None, height=dp(55), font_size=sp(14), background_color=WARNING, color=TEXT)
        btn3.bind(on_press=lambda x: setattr(self.manager, 'current', 'report'))
        content.add_widget(btn3)
        
        scroll.add_widget(content)
        layout.add_widget(scroll)
        self.add_widget(layout)
    
    def on_enter(self):
        self.user_label.text = f"👋 Добро пожаловать, {api.current_user or 'Гость'}!"
        self.update_stats()
        self.update_tasks_display()
    
    def update_stats(self):
        claims = api.get_my_claims()
        self.total.text = str(len(claims))
        self.active.text = str(len([c for c in claims if c.get('status') == 'ACTIVE']))
        self.completed.text = str(len([c for c in claims if c.get('status') == 'COMPLETED']))
    
    def update_delayed_counter(self):
        self.update_tasks_display()
    
    def update_tasks_display(self):
        count = delayed_tasks.get_pending_count()
        tasks = delayed_tasks.get_all_tasks()
        if count > 0:
            self.tasks_info.text = f"Выполняется: {count} задач"
            names = ", ".join([t['name'][:12] for t in tasks[:2]])
            self.tasks_count.text = f"📋 {names}"
        else:
            self.tasks_info.text = "Нет отложенных задач"
            self.tasks_count.text = ""
    
    def logout(self, inst):
        api.token = None
        api.current_user = None
        self.manager.current = 'login'


# ============ НОВАЯ ЗАЯВКА ============
class NewClaimScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.build_ui()
    
    def build_ui(self):
        layout = BoxLayout(orientation='vertical')
        
        top = BoxLayout(size_hint_y=None, height=dp(60), padding=[dp(10), dp(10)])
        rounded_rect(top, PRIMARY, 0)
        back = Button(text='←', size_hint_x=0.12, background_color=TEXT_LIGHT, color=CARD, font_size=sp(20))
        back.bind(on_press=lambda x: setattr(self.manager, 'current', 'main'))
        top.add_widget(back)
        top.add_widget(Label(text='СОЗДАНИЕ ЗАЯВКИ', color=CARD, bold=True, font_size=sp(16)))
        layout.add_widget(top)
        
        scroll = ScrollView()
        content = GridLayout(cols=1, padding=[dp(20), dp(15), dp(20), dp(15)], spacing=dp(12), size_hint_y=None)
        content.bind(minimum_height=content.setter('height'))
        
        content.add_widget(Label(text='ДАННЫЕ', bold=True, size_hint_y=None, height=dp(25), font_size=sp(12), color=TEXT_LIGHT))
        self.client = TextInput(hint_text='Ваше имя', multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        content.add_widget(self.client)
        
        content.add_widget(Label(text='ДЕТАЛИ ЗАЯВКИ', bold=True, size_hint_y=None, height=dp(25), font_size=sp(12), color=TEXT_LIGHT))
        self.product = Spinner(text='Выберите продукт', values=PRODUCTS, size_hint_y=None, height=dp(55), font_size=sp(14))
        self.complaint = Spinner(text='Тип жалобы', values=COMPLAINTS, size_hint_y=None, height=dp(55), font_size=sp(14))
        self.priority = Spinner(text='Средний', values=[p[1] for p in PRIORITIES], size_hint_y=None, height=dp(55), font_size=sp(14))
        content.add_widget(self.product)
        content.add_widget(self.complaint)
        content.add_widget(self.priority)
        
        content.add_widget(Label(text='НОМЕР ПАРТИИ', bold=True, size_hint_y=None, height=dp(25), font_size=sp(12), color=TEXT_LIGHT))
        self.batch = TextInput(hint_text='Номер партии (необязательно)', multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        content.add_widget(self.batch)
        
        content.add_widget(Label(text='ОПИСАНИЕ', bold=True, size_hint_y=None, height=dp(25), font_size=sp(12), color=TEXT_LIGHT))
        self.description = TextInput(hint_text='Опишите проблему подробно...', multiline=True, size_hint_y=None, height=dp(100), font_size=sp(14))
        content.add_widget(self.description)
        
        btn = Button(text='✅ ОТПРАВИТЬ ЗАЯВКУ', size_hint_y=None, height=dp(55), font_size=sp(14), background_color=SUCCESS, color=CARD)
        btn.bind(on_press=self.submit)
        content.add_widget(btn)
        
        self.msg = Label(text='', size_hint_y=None, height=dp(30), color=DANGER, font_size=sp(12))
        content.add_widget(self.msg)
        
        scroll.add_widget(content)
        layout.add_widget(scroll)
        self.add_widget(layout)
    
    def submit(self, inst):
        if not self.client.text.strip():
            self.msg.text = '❗ Введите ваше имя'
            return
        if self.product.text == 'Выберите продукт':
            self.msg.text = '❗ Выберите продукт'
            return
        if self.complaint.text == 'Тип жалобы':
            self.msg.text = '❗ Выберите тип жалобы'
            return
        if not self.description.text.strip():
            self.msg.text = '❗ Введите описание проблемы'
            return
        
        priority_val = [k for k,v in PRIORITIES if v == self.priority.text][0]
        success, claim = api.create_claim(
            self.client.text.strip(),
            self.product.text,
            self.complaint.text,
            self.description.text.strip(),
            self.batch.text.strip() or '',
            priority_val
        )
        
        if success:
            delayed_tasks.add_task(f"Обработка заявки #{claim['id']}", 10)
            self.msg.text = f'✅ Заявка #{claim["id"]} создана!\n⏰ Задача через 10 сек'
            self.msg.color = SUCCESS
            Clock.schedule_once(lambda dt: setattr(self.manager, 'current', 'main'), 2)
        else:
            self.msg.text = '❌ Ошибка создания заявки'
            self.msg.color = DANGER


# ============ МОИ ЗАЯВКИ ============
class MyClaimsScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.current_filter = 'all'
        self.build_ui()
    
    def build_ui(self):
        layout = BoxLayout(orientation='vertical')
        
        top = BoxLayout(size_hint_y=None, height=dp(60), padding=[dp(10), dp(10)])
        rounded_rect(top, PRIMARY, 0)
        back = Button(text='←', size_hint_x=0.12, background_color=TEXT_LIGHT, color=CARD, font_size=sp(20))
        back.bind(on_press=lambda x: setattr(self.manager, 'current', 'main'))
        top.add_widget(back)
        top.add_widget(Label(text='МОИ ЗАЯВКИ', color=CARD, bold=True, font_size=sp(16)))
        layout.add_widget(top)
        
        filters = GridLayout(cols=4, size_hint_y=None, height=dp(50), spacing=dp(5), padding=[dp(5), dp(8)])
        self.btn_all = Button(text='Все', background_color=INFO, color=CARD, font_size=sp(11))
        self.btn_new = Button(text='Новые', background_color=TEXT_LIGHT, color=CARD, font_size=sp(11))
        self.btn_active = Button(text='В работе', background_color=TEXT_LIGHT, color=CARD, font_size=sp(11))
        self.btn_done = Button(text='Заверш.', background_color=TEXT_LIGHT, color=CARD, font_size=sp(11))
        
        self.btn_all.bind(on_press=lambda x: self.set_filter('all'))
        self.btn_new.bind(on_press=lambda x: self.set_filter('new'))
        self.btn_active.bind(on_press=lambda x: self.set_filter('active'))
        self.btn_done.bind(on_press=lambda x: self.set_filter('done'))
        
        filters.add_widget(self.btn_all)
        filters.add_widget(self.btn_new)
        filters.add_widget(self.btn_active)
        filters.add_widget(self.btn_done)
        layout.add_widget(filters)
        
        scroll = ScrollView()
        self.claims_list = GridLayout(cols=1, spacing=dp(10), padding=[dp(12), dp(8), dp(12), dp(8)], size_hint_y=None)
        self.claims_list.bind(minimum_height=self.claims_list.setter('height'))
        scroll.add_widget(self.claims_list)
        layout.add_widget(scroll)
        self.add_widget(layout)
    
    def set_filter(self, f):
        self.current_filter = f
        btns = [self.btn_all, self.btn_new, self.btn_active, self.btn_done]
        for btn in btns:
            btn.background_color = TEXT_LIGHT
        if f == 'all':
            self.btn_all.background_color = INFO
        elif f == 'new':
            self.btn_new.background_color = INFO
        elif f == 'active':
            self.btn_active.background_color = INFO
        elif f == 'done':
            self.btn_done.background_color = INFO
        self.update_list()
    
    def on_enter(self):
        self.update_list()
    
    def update_list(self):
        self.claims_list.clear_widgets()
        claims = api.get_my_claims()
        
        filtered = []
        for c in claims:
            status = c.get('status', 'CREATED')
            if self.current_filter == 'all':
                filtered.append(c)
            elif self.current_filter == 'new' and status == 'CREATED':
                filtered.append(c)
            elif self.current_filter == 'active' and status == 'ACTIVE':
                filtered.append(c)
            elif self.current_filter == 'done' and status == 'COMPLETED':
                filtered.append(c)
        
        if not filtered:
            self.claims_list.add_widget(Label(text='Нет заявок', color=TEXT_LIGHT, size_hint_y=None, height=dp(60), font_size=sp(14)))
            return
        
        for c in filtered:
            priority = c.get('priority', 'medium')
            priority_name = {'low': 'Низкий', 'medium': 'Средний', 'high': 'Высокий', 'critical': 'Критический'}.get(priority, 'Средний')
            status = c.get('status', 'CREATED')
            status_text = {'CREATED': '🟡 Новая', 'ACTIVE': '🟠 В работе', 'COMPLETED': '✅ Завершена'}.get(status, 'Новая')
            
            card = BoxLayout(orientation='vertical', size_hint_y=None, height=dp(150), padding=[dp(12), dp(10)], spacing=dp(6))
            rounded_rect(card, CARD, dp(12))
            
            header = BoxLayout(size_hint_y=None, height=dp(30))
            header.add_widget(Label(text=f"Заявка #{c['id']}", bold=True, font_size=sp(13), size_hint_x=0.5))
            header.add_widget(Label(text=priority_name, color=WARNING if priority == 'medium' else DANGER, font_size=sp(11), size_hint_x=0.5, halign='right'))
            card.add_widget(header)
            
            card.add_widget(Label(text=c['product'], bold=True, font_size=sp(15), size_hint_y=None, height=dp(30), color=PRIMARY))
            
            footer = BoxLayout(size_hint_y=None, height=dp(30))
            footer.add_widget(Label(text=f"Партия: {c.get('batch', '-')}", color=TEXT_LIGHT, font_size=sp(11), size_hint_x=0.6))
            footer.add_widget(Label(text=status_text, color=SUCCESS if status == 'COMPLETED' else INFO, font_size=sp(11), size_hint_x=0.4, halign='right'))
            card.add_widget(footer)
            
            btn = Button(text='ПОДРОБНЕЕ', size_hint_y=None, height=dp(35), font_size=sp(12), background_color=INFO, color=CARD)
            btn.bind(on_press=lambda x, cid=c['id']: self.show_details(cid))
            card.add_widget(btn)
            
            self.claims_list.add_widget(card)
    
    def show_details(self, cid):
        claim = api.get_claim_by_id(cid)
        if not claim:
            show_message('Ошибка', 'Не удалось загрузить заявку')
            return
        
        priority_name = {'low': 'Низкий', 'medium': 'Средний', 'high': 'Высокий', 'critical': 'Критический'}.get(claim.get('priority', 'medium'), 'Средний')
        status_text = {'CREATED': 'Новая', 'ACTIVE': 'В работе', 'COMPLETED': 'Завершена'}.get(claim.get('status', 'CREATED'), 'Новая')
        
        content = BoxLayout(orientation='vertical', spacing=dp(10), padding=dp(15))
        content.add_widget(Label(text=f"ЗАЯВКА #{claim['id']}", font_size=sp(18), bold=True, size_hint_y=None, height=dp(35)))
        content.add_widget(Label(text=f"Клиент: {claim.get('client', '-')}", font_size=sp(13)))
        content.add_widget(Label(text=f"Продукт: {claim.get('product', '-')}", font_size=sp(13)))
        content.add_widget(Label(text=f"Тип: {claim.get('complaint_type', '-')}", font_size=sp(13)))
        content.add_widget(Label(text=f"Партия: {claim.get('batch', '-')}", font_size=sp(13)))
        content.add_widget(Label(text=f"Приоритет: {priority_name}", font_size=sp(13)))
        content.add_widget(Label(text=f"Статус: {status_text}", font_size=sp(13)))
        content.add_widget(Label(text=f"Описание: {claim.get('description', '-')}", size_hint_y=None, font_size=sp(12)))
        
        btn = Button(text='ЗАКРЫТЬ', size_hint_y=0.1, background_color=PRIMARY, color=CARD, font_size=sp(14))
        popup = Popup(title='Детали заявки', content=content, size_hint=(0.9, 0.7))
        btn.bind(on_press=lambda x: popup.dismiss())
        content.add_widget(btn)
        popup.open()


# ============ ОТЧЁТЫ ============
class ReportScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.build_ui()
    
    def build_ui(self):
        layout = BoxLayout(orientation='vertical')
        
        top = BoxLayout(size_hint_y=None, height=dp(60), padding=[dp(10), dp(10)])
        rounded_rect(top, PRIMARY, 0)
        back = Button(text='←', size_hint_x=0.12, background_color=TEXT_LIGHT, color=CARD, font_size=sp(20))
        back.bind(on_press=lambda x: setattr(self.manager, 'current', 'main'))
        top.add_widget(back)
        top.add_widget(Label(text='ОТЧЁТЫ', color=CARD, bold=True, font_size=sp(18)))
        layout.add_widget(top)
        
        scroll = ScrollView()
        content = GridLayout(cols=1, padding=[dp(25), dp(20), dp(25), dp(20)], spacing=dp(15), size_hint_y=None)
        content.bind(minimum_height=content.setter('height'))
        
        # Блок создания отчёта
        content.add_widget(Label(text='ПОИСК ПО ПАРТИИ', bold=True, size_hint_y=None, height=dp(35), font_size=sp(14), color=PRIMARY))
        
        self.batch_input = TextInput(hint_text='Номер партии', multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        content.add_widget(self.batch_input)
        
        btn_create = Button(text='СОЗДАТЬ ОТЧЁТ', size_hint_y=None, height=dp(55), font_size=sp(14), background_color=SUCCESS, color=CARD)
        btn_create.bind(on_press=self.create_report)
        content.add_widget(btn_create)
        
        self.result = Label(text='', color=TEXT_LIGHT, size_hint_y=None, height=dp(40), font_size=sp(12))
        content.add_widget(self.result)
        
        # Разделитель
        content.add_widget(Label(text='', size_hint_y=None, height=dp(10)))
        content.add_widget(Label(text='📋 СПИСОК ОТЧЁТОВ', bold=True, size_hint_y=None, height=dp(35), font_size=sp(14), color=PRIMARY))
        
        # Контейнер для списка отчётов
        self.reports_container = GridLayout(cols=1, spacing=dp(10), size_hint_y=None)
        self.reports_container.bind(minimum_height=self.reports_container.setter('height'))
        content.add_widget(self.reports_container)
        
        # Кнопка обновления
        btn_refresh = Button(text='🔄 ОБНОВИТЬ', size_hint_y=None, height=dp(45), font_size=sp(13), background_color=INFO, color=CARD)
        btn_refresh.bind(on_press=lambda x: self.load_reports())
        content.add_widget(btn_refresh)
        
        scroll.add_widget(content)
        layout.add_widget(scroll)
        self.add_widget(layout)
    
    def on_enter(self):
        self.load_reports()
    
    def load_reports(self):
        """Загрузить список отчётов с сервера"""
        self.reports_container.clear_widgets()
        reports = api.get_reports_list()
        
        if not reports:
            self.reports_container.add_widget(Label(
                text='Нет созданных отчётов', 
                color=TEXT_LIGHT, 
                size_hint_y=None, 
                height=dp(50),
                font_size=sp(12)
            ))
            return
        
        for report in reports:
            filename = report.get('filename', '')
            batch = report.get('batch', '')
            if not batch and filename.startswith('report_batch_'):
                batch = filename.replace('report_batch_', '').split('_')[0]
            
            created = report.get('created', '')
            if created and len(created) > 16:
                created = created[:16]
            
            # Карточка отчёта
            card = BoxLayout(orientation='vertical', size_hint_y=None, height=dp(100), padding=[dp(12), dp(10)], spacing=dp(5))
            rounded_rect(card, CARD, dp(12))
            
            # Заголовок
            header = BoxLayout(orientation='horizontal', size_hint_y=None, height=dp(30))
            header.add_widget(Label(text=f"📄 Партия: {batch}", bold=True, font_size=sp(13), size_hint_x=0.6))
            header.add_widget(Label(text=created, color=TEXT_LIGHT, font_size=sp(11), size_hint_x=0.4, halign='right'))
            card.add_widget(header)
            
            # Имя файла
            card.add_widget(Label(text=filename, color=TEXT_LIGHT, size_hint_y=None, height=dp(25), font_size=sp(10)))
            
            # Кнопка просмотра
            btn_view = Button(text='ПОСМОТРЕТЬ ОТЧЁТ', size_hint_y=None, height=dp(35), font_size=sp(12), background_color=INFO, color=CARD)
            btn_view.bind(on_press=lambda x, f=filename: self.view_report(f))
            card.add_widget(btn_view)
            
            self.reports_container.add_widget(card)
    
    def view_report(self, filename):
        """Просмотреть содержимое отчёта"""
        report = api.download_report(filename)
        if report and report.get('content'):
            content = BoxLayout(orientation='vertical', spacing=dp(10), padding=dp(15))
            
            scroll = ScrollView()
            text_label = Label(text=report['content'], size_hint_y=None, font_size=sp(11))
            text_label.bind(texture_size=lambda inst, val: setattr(inst, 'height', val[1]))
            scroll.add_widget(text_label)
            content.add_widget(scroll)
            
            btn_close = Button(text='ЗАКРЫТЬ', size_hint_y=0.1, background_color=PRIMARY, color=CARD, font_size=sp(14))
            btn_close.bind(on_press=lambda x: popup.dismiss())
            content.add_widget(btn_close)
            
            popup = Popup(title=f'Отчёт: {filename}', content=content, size_hint=(0.95, 0.85))
            popup.open()
        else:
            show_message('Ошибка', 'Не удалось загрузить отчёт')
    
    def create_report(self, instance):
        batch = self.batch_input.text.strip()
        if not batch:
            show_message('Ошибка', 'Введите номер партии!')
            return
        
        if not api.token:
            show_message('Ошибка', 'Ошибка авторизации!')
            return
        
        success, result = api.generate_report_on_server(batch)
        if success:
            self.result.text = f'✅ Отчёт "{result["filename"]}" создан!'
            self.result.color = SUCCESS
            self.batch_input.text = ''
            show_message('Успех', f'Отчёт сохранён на сервере!\nФайл: {result["filename"]}')
            self.load_reports()
            Clock.schedule_once(lambda dt: setattr(self.result, 'text', ''), 3)
        else:
            self.result.text = '❌ Заявка с такой партией не найдена'
            self.result.color = DANGER
            Clock.schedule_once(lambda dt: setattr(self.result, 'text', ''), 3)


# ============ ПРИЛОЖЕНИЕ ============
class FoodFactoryApp(App):
    def build(self):
        sm = ScreenManager()
        sm.add_widget(LoginScreen(name='login'))
        sm.add_widget(RegisterScreen(name='register'))
        sm.add_widget(MainScreen(name='main'))
        sm.add_widget(NewClaimScreen(name='new_claim'))
        sm.add_widget(MyClaimsScreen(name='my_claims'))
        sm.add_widget(ReportScreen(name='report'))
        return sm


if __name__ == '__main__':
    FoodFactoryApp().run()
