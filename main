# ============ ОТЛОЖЕННЫЕ ЗАДАЧИ ============
class DelayedTask:
    def __init__(self, task_id, name, delay):
        self.id = task_id
        self.name = name
        self.delay = delay
        self.status = "pending"
        self.created_at = datetime.now()
        self.execute_at = time.time() + delay

class DelayedTaskManager:
    _instance = None
    _tasks = []
    _observers = []

    def __new__(cls):
        if cls._instance is None:
            cls._instance = super().__new__(cls)
            cls._instance._start_worker()
        return cls._instance

    def _start_worker(self):
        self._running = True
        self._thread = threading.Thread(target=self._worker_loop, daemon=True)
        self._thread.start()

    def add_task(self, name, delay_seconds):
        task_id = str(uuid.uuid4())[:8]
        task = DelayedTask(task_id, name, delay_seconds)
        self._tasks.append(task)
        self._notify_observers()
        return task_id

    def get_pending_count(self):
        return len([t for t in self._tasks if t.status == "pending"])

    def get_all_tasks(self):
        return [{"id": t.id, "name": t.name, "status": t.status, "delay": t.delay, "remaining": max(0, int(t.execute_at - time.time()))} for t in self._tasks]

    def add_observer(self, obs):
        if obs not in self._observers:
            self._observers.append(obs)

    def _notify_observers(self):
        for obs in self._observers:
            Clock.schedule_once(lambda dt: obs.update_delayed_counter(), 0)

    def _worker_loop(self):
        while self._running:
            now = time.time()
            for t in self._tasks[:]:
                if t.status == "pending" and t.execute_at <= now:
                    t.status = "completed"
                    self._notify_observers()
                    self._tasks.remove(t)
            time.sleep(0.5)

delayed_tasks = DelayedTaskManager()


# ============ API КЛИЕНТ ============
class APIClient:
    _instance = None
    def __new__(cls):
        if cls._instance is None:
            cls._instance = super().__new__(cls)
            cls._instance.token = None
            cls._instance.current_user = None
        return cls._instance

    def get_headers(self):
        return {'Authorization': f'Bearer {self.token}'} if self.token else {}

    def login(self, username, password):
        try:
            r = requests.post(f"{API_URL}/auth/login", json={'login': username, 'password': password}, timeout=5)
            if r.status_code == 200:
                self.token = r.json().get('access_token')
                self.current_user = username
                return True
        except:
            pass
        return False

    def register(self, full_name, username, password):
        try:
            r = requests.post(f"{API_URL}/users/", json={'full_name': full_name, 'login': username, 'password': password}, timeout=5)
            return r.status_code == 201
        except:
            return False

    def create_claim(self, client, product, complaint, desc, batch, priority):
        try:
            r = requests.post(f"{API_URL}/claims/", json={
                'client': client, 'product': product, 'complaint_type': complaint,
                'description': desc, 'batch': batch, 'priority': priority
            }, headers=self.get_headers(), timeout=10)
            if r.status_code == 201:
                return True, r.json()
        except:
            pass
        return False, None

    def get_my_claims(self):
        try:
            r = requests.get(f"{API_URL}/claims/", headers=self.get_headers(), timeout=5)
            return r.json() if r.status_code == 200 else []
        except:
            return []

    def get_claim_by_batch(self, batch):
        try:
            r = requests.get(f"{API_URL}/claims/by-batch/{batch}", headers=self.get_headers(), timeout=5)
            if r.status_code == 200:
                return r.json()
            return None
        except:
            return None

    def get_claim_by_id(self, cid):
        try:
            r = requests.get(f"{API_URL}/claims/{cid}", headers=self.get_headers(), timeout=5)
            if r.status_code == 200:
                return r.json()
            return None
        except:
            return None

    def generate_report_on_server(self, batch):
        try:
            r = requests.get(f"{API_URL}/claims/generate-report/{batch}", headers=self.get_headers(), timeout=10)
            if r.status_code == 200:
                return True, r.json()
            return False, None
        except:
            return False, None

    def get_reports_list(self):
        try:
            r = requests.get(f"{API_URL}/claims/reports/list", headers=self.get_headers(), timeout=5)
            if r.status_code == 200:
                return r.json().get('reports', [])
            return []
        except:
            return []

    def download_report(self, filename):
        try:
            r = requests.get(f"{API_URL}/claims/reports/download/{filename}", headers=self.get_headers(), timeout=10)
            if r.status_code == 200:
                return r.json()
            return None
        except:
            return None

api = APIClient()


# ============ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ============
def rounded_rect(widget, color=CARD, radius=dp(12)):
    with widget.canvas.before:
        Color(*color)
        rect = RoundedRectangle(size=widget.size, pos=widget.pos, radius=[radius])
        widget.bind(size=lambda i,s: setattr(rect, 'size', s), pos=lambda i,p: setattr(rect, 'pos', p))

def show_message(title, text):
    popup = Popup(title=title, content=Label(text=text, font_size=sp(14)), size_hint=(0.8, 0.3))
    popup.open()
    Clock.schedule_once(lambda dt: popup.dismiss(), 2)


# ============ ЭКРАН ВХОДА ============
class LoginScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.build_ui()

    def build_ui(self):
        layout = BoxLayout(orientation='vertical', padding=[dp(30), dp(40), dp(30), dp(40)], spacing=dp(20))
        
        layout.add_widget(Label(text='🍔 FOOD FACTORY', font_size=sp(36), bold=True, color=PRIMARY, size_hint_y=None, height=dp(70)))
        layout.add_widget(Label(text='Система контроля качества', font_size=sp(12), color=TEXT_LIGHT, size_hint_y=None, height=dp(30)))
        
        self.username = TextInput(hint_text='Логин', multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        self.password = TextInput(hint_text='Пароль', password=True, multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        
        layout.add_widget(self.username)
        layout.add_widget(self.password)
        
        btn_login = Button(text='ВОЙТИ', size_hint_y=None, height=dp(55), font_size=sp(16), background_color=SUCCESS, color=CARD)
        btn_login.bind(on_press=self.do_login)
        layout.add_widget(btn_login)
        
        btn_reg = Button(text='РЕГИСТРАЦИЯ', size_hint_y=None, height=dp(50), font_size=sp(14), background_color=INFO, color=CARD)
        btn_reg.bind(on_press=lambda x: setattr(self.manager, 'current', 'register'))
        layout.add_widget(btn_reg)
        
        self.error = Label(text='', color=DANGER, size_hint_y=None, height=dp(30), font_size=sp(12))
        layout.add_widget(self.error)
        
        self.add_widget(layout)

    def do_login(self, inst):
        if api.login(self.username.text.strip(), self.password.text.strip()):
            self.manager.current = 'main'
        else:
            self.error.text = 'Неверный логин или пароль!'


# ============ ЭКРАН РЕГИСТРАЦИИ ============
class RegisterScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.build_ui()

    def build_ui(self):
        layout = BoxLayout(orientation='vertical')
        
        top = BoxLayout(size_hint_y=None, height=dp(60), padding=[dp(10), dp(10)])
        rounded_rect(top, PRIMARY, 0)
        back = Button(text='←', size_hint_x=0.12, background_color=TEXT_LIGHT, color=CARD, font_size=sp(20))
        back.bind(on_press=lambda x: setattr(self.manager, 'current', 'login'))
        top.add_widget(back)
        top.add_widget(Label(text='РЕГИСТРАЦИЯ', color=CARD, bold=True, font_size=sp(18)))
        layout.add_widget(top)
        
        scroll = ScrollView()
        content = GridLayout(cols=1, padding=[dp(25), dp(20), dp(25), dp(20)], spacing=dp(15), size_hint_y=None)
        content.bind(minimum_height=content.setter('height'))
        
        self.full_name = TextInput(hint_text='Ваше имя', multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        self.username = TextInput(hint_text='Логин', multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        self.password = TextInput(hint_text='Пароль', password=True, multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        self.confirm = TextInput(hint_text='Подтвердите пароль', password=True, multiline=False, size_hint_y=None, height=dp(55), font_size=sp(14))
        
        content.add_widget(self.full_name)
        content.add_widget(self.username)
        content.add_widget(self.password)
        content.add_widget(self.confirm)
        
        btn = Button(text='ЗАРЕГИСТРИРОВАТЬСЯ', size_hint_y=None, height=dp(55), font_size=sp(16), background_color=SUCCESS, color=CARD)
        btn.bind(on_press=self.do_register)
        content.add_widget(btn)
        
        scroll.add_widget(content)
        layout.add_widget(scroll)
        self.add_widget(layout)

    def do_register(self, inst):
        if not self.full_name.text.strip() or not self.username.text.strip() or not self.password.text.strip():
            show_message('Ошибка', 'Заполните все поля!')
            return
        if self.password.text != self.confirm.text:
            show_message('Ошибка', 'Пароли не совпадают!')
            return
        if api.register(self.full_name.text.strip(), self.username.text.strip(), self.password.text.strip()):
            show_message('Успех', 'Регистрация успешна!')
            Clock.schedule_once(lambda dt: setattr(self.manager, 'current', 'login'), 1.5)
        else:
            show_message('Ошибка', 'Ошибка регистрации!')


